/**
 * Core Philosophy: This ruleset enforces a sophisticated role-based access control (RBAC) model
 * centered on a care network. An 'Elderly' user's private data can be accessed by the user themselves,
 * their designated 'Caregivers', and associated 'Professionals'. Access is also provided for collaborative
 * 'Community' groups and globally privileged 'Admins'.
 *
 * Data Structure:
 * - /user_profiles/{userId}: Core document for all user types. Sensitive health data for 'Elderly' users
 *   is nested within this path (e.g., /user_profiles/{elderlyUserId}/health_metrics).
 * - /communities/{communityId}: Collaborative spaces with their own subcollections for messages and events.
 * - /admin_roles/{userId}: An existence-based collection to efficiently grant global admin rights.
 * - Root-level collections (/events, /knowledge_resources) for public or globally-scoped data.
 *
 * Key Security Decisions:
 * - Authorization Independence: To ensure performance and security, rules avoid cross-document `get()`
 *   calls wherever possible. However, `get()` is used pragmatically to check a user's role on their
 *   own profile or to verify membership in a care network (e.g., checking an Elderly user's `caregiverIds`)
 *   for list operations, which is a necessary and efficient pattern.
 * - Care Network Access: An Elderly user's data is accessible by a closed group of collaborators
 *   (the user, their caregivers, their professionals). This is managed by checking arrays on the
 *   parent Elderly user's profile document.
 * - Community Membership: Access to community-specific data (messages, events) is restricted to users
 *   listed in the parent community's `memberIds` array.
 * - No User Enumeration: Listing the top-level `/user_profiles` collection is disabled to protect user privacy.
 * - Admin Privileges: Admins have read/write access across most of the database for moderation and
 *   administrative purposes. This is managed via the `isAdmin()` helper function.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for reusable logic
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user has a document in the admin_roles collection.
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // Checks if the user is the Elderly patient, one of their linked caregivers/professionals, or an admin.
    // This requires a 'get' call to the Elderly user's profile to check the linked user arrays.
    function isMemberOfCareNetwork(elderlyUserId) {
      let userProfile = get(/databases/$(database)/documents/user_profiles/$(elderlyUserId)).data;
      return isOwner(elderlyUserId) ||
             request.auth.uid in userProfile.caregiverIds ||
             request.auth.uid in userProfile.professionalIds ||
             isAdmin();
    }

    // Checks if the user is a member of a community by reading the parent community document.
    function isCommunityMember(communityId) {
      let community = get(/databases/$(database)/documents/communities/$(communityId)).data;
      return isSignedIn() && request.auth.uid in community.memberIds;
    }

    // Checks if the user has a 'Professional' role or is an admin.
    // This requires a 'get' to the user's own profile, which is an acceptable pattern.
    function isProfessionalOrAdmin() {
      let userProfile = get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
      return isAdmin() || userProfile.role == 'Professional';
    }


    /**
     * @description Manages user profile data. A user can create, read, and write their own profile.
     * @path /user_profiles/{userId}
     * @allow (create) An authenticated user creating their own profile document: `auth.uid == userId`.
     * @deny (list) Any user attempting to list all user profiles.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /user_profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if (isOwner(userId) || isAdmin()) && resource != null;
    }

    /**
     * @description Manages global admin roles. Existence of a doc grants admin privileges.
     * @path /admin_roles/{userId}
     * @allow (create) An existing admin adding a new admin.
     * @deny (create) A non-admin user attempting to grant themselves admin rights.
     * @principle Enforces privilege control; only admins can manage other admins.
     */
    match /admin_roles/{userId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Secures health metrics for an Elderly user.
     * @path /user_profiles/{elderlyUserId}/health_metrics/{healthMetricId}
     * @allow (get, list) The elderly user or their linked caregivers/professionals reading the metrics.
     * @deny (create) A user not in the care network attempting to add a health metric.
     * @principle Enforces closed collaborator access based on the parent user's care network.
     */
    match /user_profiles/{elderlyUserId}/health_metrics/{healthMetricId} {
      allow get, list: if isMemberOfCareNetwork(elderlyUserId);
      allow create: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == elderlyUserId && request.resource.data.recordedByUserId == request.auth.uid;
      allow update: if isMemberOfCareNetwork(elderlyUserId) && resource != null && request.resource.data.elderlyUserId == resource.data.elderlyUserId;
      allow delete: if isMemberOfCareNetwork(elderlyUserId) && resource != null;
    }

    /**
     * @description Secures medication records for an Elderly user.
     * @path /user_profiles/{elderlyUserId}/medications/{medicationId}
     * @allow (get, list) The elderly user or their linked caregivers/professionals viewing medications.
     * @deny (create) An unassociated user attempting to add a medication record.
     * @principle Enforces closed collaborator access based on the parent user's care network.
     */
    match /user_profiles/{elderlyUserId}/medications/{medicationId} {
      allow get, list: if isMemberOfCareNetwork(elderlyUserId);
      allow create: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == elderlyUserId;
      allow update: if isMemberOfCareNetwork(elderlyUserId) && resource != null && request.resource.data.elderlyUserId == resource.data.elderlyUserId;
      allow delete: if isMemberOfCareNetwork(elderlyUserId) && resource != null;
    }

    /**
     * @description Secures medication adherence records.
     * @path /user_profiles/{elderlyUserId}/medications/{medicationId}/adherence_records/{adherenceId}
     * @allow (create) A member of the care network recording that a medication was taken.
     * @deny (get) A user outside the care network trying to read adherence data.
     * @principle Enforces closed collaborator access based on the grandparent user's care network.
     */
    match /user_profiles/{elderlyUserId}/medications/{medicationId}/adherence_records/{adherenceId} {
      allow get, list: if isMemberOfCareNetwork(elderlyUserId);
      allow create: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == elderlyUserId && request.resource.data.recordedByUserId == request.auth.uid;
      allow update: if isMemberOfCareNetwork(elderlyUserId) && resource != null && request.resource.data.elderlyUserId == resource.data.elderlyUserId;
      allow delete: if isMemberOfCareNetwork(elderlyUserId) && resource != null;
    }

    /**
     * @description Secures general health log entries for an Elderly user.
     * @path /user_profiles/{elderlyUserId}/health_logs/{healthLogId}
     * @allow (get, list) The elderly user or their linked caregivers/professionals reading logs.
     * @deny (create) An unassociated user attempting to add a health log.
     * @principle Enforces closed collaborator access based on the parent user's care network.
     */
    match /user_profiles/{elderlyUserId}/health_logs/{healthLogId} {
      allow get, list: if isMemberOfCareNetwork(elderlyUserId);
      allow create: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == elderlyUserId && request.resource.data.recordedByUserId == request.auth.uid;
      allow update: if isMemberOfCareNetwork(elderlyUserId) && resource != null && request.resource.data.elderlyUserId == resource.data.elderlyUserId;
      allow delete: if isMemberOfCareNetwork(elderlyUserId) && resource != null;
    }

    /**
     * @description Secures daily check-in data submitted by an Elderly user.
     * @path /user_profiles/{elderlyUserId}/daily_check_ins/{checkInId}
     * @allow (get, list) The elderly user or their linked caregivers/professionals viewing check-ins.
     * @deny (create) Anyone other than the Elderly user submitting a daily check-in for them.
     * @principle Enforces closed collaborator access, but creation is restricted to the subject user.
     */
    match /user_profiles/{elderlyUserId}/daily_check_ins/{checkInId} {
      allow get, list: if isMemberOfCareNetwork(elderlyUserId);
      allow create: if isOwner(elderlyUserId) && request.resource.data.elderlyUserId == elderlyUserId;
      allow update: if isOwner(elderlyUserId) && resource != null && request.resource.data.elderlyUserId == resource.data.elderlyUserId;
      allow delete: if isOwner(elderlyUserId) && resource != null;
    }

    /**
     * @description A user's outbox for private messages.
     * @path /user_profiles/{senderId}/sent_messages/{messageId}
     * @allow (create) A user sending a message: `auth.uid == senderId`.
     * @deny (get) Another user trying to read someone's sent messages.
     * @principle Enforces strict ownership over a user's private data.
     */
    match /user_profiles/{senderId}/sent_messages/{messageId} {
      allow get, list: if isOwner(senderId);
      allow create: if isOwner(senderId) && request.resource.data.senderId == senderId;
      allow update: if false;
      allow delete: if isOwner(senderId) && resource != null;
    }

    /**
     * @description A user's inbox for private messages.
     * @path /user_profiles/{receiverId}/inbox_messages/{messageId}
     * @allow (get) A user reading a message they received: `auth.uid == receiverId`.
     * @deny (create) A user trying to write directly into another user's inbox.
     * @principle Enforces strict ownership; assumes a backend function handles message fan-out.
     */
    match /user_profiles/{receiverId}/inbox_messages/{messageId} {
      allow get, list: if isOwner(receiverId);
      allow create: if false;
      allow update: if isOwner(receiverId) && resource != null && request.resource.data.receiverId == resource.data.receiverId && request.resource.data.senderId == resource.data.senderId;
      allow delete: if isOwner(receiverId) && resource != null;
    }

    /**
     * @description Defines a community group.
     * @path /communities/{communityId}
     * @allow (get) A member of the community reading its details.
     * @deny (update) A regular member trying to change the community description.
     * @principle Enforces membership for reads and creator-ownership for writes. Allows discovery.
     */
    match /communities/{communityId} {
      allow get: if isCommunityMember(communityId) || isAdmin();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUserId == request.auth.uid && request.auth.uid in request.resource.data.memberIds;
      allow update: if (isOwner(resource.data.createdByUserId) || isAdmin()) && resource != null;
      allow delete: if (isOwner(resource.data.createdByUserId) || isAdmin()) && resource != null;
    }

    /**
     * @description Messages within a specific community.
     * @path /communities/{communityId}/messages/{messageId}
     * @allow (create) A community member posting a new message.
     * @deny (list) A non-member trying to read the community's messages.
     * @principle Enforces that only community members can read or post messages.
     */
    match /communities/{communityId}/messages/{messageId} {
      allow get, list: if isCommunityMember(communityId) || isAdmin();
      allow create: if isCommunityMember(communityId) && request.resource.data.senderId == request.auth.uid && request.resource.data.communityId == communityId;
      allow update: if (isOwner(resource.data.senderId) || isAdmin()) && resource != null;
      allow delete: if (isOwner(resource.data.senderId) || isAdmin()) && resource != null;
    }

    /**
     * @description Events scheduled within a specific community.
     * @path /communities/{communityId}/events/{eventId}
     * @allow (create) A community member creating a new event for the group.
     * @deny (get) A non-member trying to view a private community event.
     * @principle Enforces that only community members can interact with community events.
     */
    match /communities/{communityId}/events/{eventId} {
      allow get, list: if isCommunityMember(communityId) || isAdmin();
      allow create: if isCommunityMember(communityId) && request.resource.data.creatorId == request.auth.uid && request.resource.data.communityId == communityId;
      allow update: if (isOwner(resource.data.creatorId) || isAdmin()) && resource != null;
      allow delete: if (isOwner(resource.data.creatorId) || isAdmin()) && resource != null;
    }

    /**
     * @description Stand-alone events not tied to a specific community.
     * @path /events/{eventId}
     * @allow (get, list) Any user, signed in or not, viewing public event details.
     * @deny (update) A user who did not create the event trying to change its time.
     * @principle Implements a public-read, owner-only write model.
     */
    match /events/{eventId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && request.query.where('attendeeIds', 'array-contains', request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if (isOwner(resource.data.creatorId) || isAdmin()) && resource != null;
      allow delete: if (isOwner(resource.data.creatorId) || isAdmin()) && resource != null;
    }

    /**
     * @description Informational articles and guides for users.
     * @path /knowledge_resources/{resourceId}
     * @allow (get, list) Any user, signed in or not, reading a knowledge resource.
     * @deny (create) A regular user attempting to publish an article.
     * @principle Implements public-read with writes restricted to authors (Professionals/Admins).
     */
    match /knowledge_resources/{resourceId} {
      allow get, list: if true;
      allow create: if isProfessionalOrAdmin() && request.resource.data.authorId == request.auth.uid;
      allow update: if (isOwner(resource.data.authorId) || isAdmin()) && resource != null;
      allow delete: if (isOwner(resource.data.authorId) || isAdmin()) && resource != null;
    }

  }
}

    