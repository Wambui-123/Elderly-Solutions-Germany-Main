
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    function isMemberOfCareNetwork(elderlyUserId) {
      let userProfile = get(/databases/$(database)/documents/user_profiles/$(elderlyUserId)).data;
      return isOwner(elderlyUserId) ||
             (userProfile.caregiverIds != null && userProfile.caregiverIds.hasAny([request.auth.uid])) ||
             (userProfile.professionalIds != null && userProfile.professionalIds.hasAny([request.auth.uid])) ||
             isAdmin();
    }

    function isCommunityMember(communityId) {
      let community = get(/databases/$(database)/documents/communities/$(communityId)).data;
      return isSignedIn() && (community.memberIds != null && community.memberIds.hasAny([request.auth.uid]));
    }

    function isProfessionalOrAdmin() {
      let userProfile = get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
      return isAdmin() || userProfile.role == 'Professional';
    }

    // -------------------------------
    // User Profiles
    match /user_profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /admin_roles/{userId} {
      allow read, write: if isAdmin();
    }

    match /user_profiles/{elderlyUserId}/health_metrics/{healthMetricId} {
      allow get, list: if isMemberOfCareNetwork(elderlyUserId);
      allow create: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == elderlyUserId && request.resource.data.recordedByUserId == request.auth.uid;
      allow update: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == resource.data.elderlyUserId;
      allow delete: if isMemberOfCareNetwork(elderlyUserId);
    }

    match /user_profiles/{elderlyUserId}/medications/{medicationId} {
      allow get, list: if isMemberOfCareNetwork(elderlyUserId);
      allow create: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == elderlyUserId;
      allow update: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == resource.data.elderlyUserId;
      allow delete: if isMemberOfCareNetwork(elderlyUserId);
    }

    match /user_profiles/{elderlyUserId}/medications/{medicationId}/adherence_records/{adherenceId} {
      allow get, list: if isMemberOfCareNetwork(elderlyUserId);
      allow create: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == elderlyUserId && request.resource.data.recordedByUserId == request.auth.uid;
      allow update: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == resource.data.elderlyUserId;
      allow delete: if isMemberOfCareNetwork(elderlyUserId);
    }

    match /user_profiles/{elderlyUserId}/health_logs/{healthLogId} {
      allow get, list: if isMemberOfCareNetwork(elderlyUserId);
      allow create: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == elderlyUserId && request.resource.data.recordedByUserId == request.auth.uid;
      allow update: if isMemberOfCareNetwork(elderlyUserId) && request.resource.data.elderlyUserId == resource.data.elderlyUserId;
      allow delete: if isMemberOfCareNetwork(elderlyUserId);
    }

    match /user_profiles/{elderlyUserId}/daily_check_ins/{checkInId} {
      allow get, list: if isMemberOfCareNetwork(elderlyUserId);
      allow create: if isOwner(elderlyUserId) && request.resource.data.elderlyUserId == elderlyUserId;
      allow update: if isOwner(elderlyUserId) && request.resource.data.elderlyUserId == resource.data.elderlyUserId;
      allow delete: if isOwner(elderlyUserId);
    }

    // -------------------------------
    // Conversations
    match /conversations/{conversationId} {
      // Get only if the user is a participant
      allow get: if isSignedIn() && resource.data.participantIds.hasAny([request.auth.uid]);

      // List conversations: allow signed-in users, frontend must filter by participantIds
      allow list: if isSignedIn();

      // Create/Update only if user is a participant
      allow write: if isSignedIn() && request.resource.data.participantIds.hasAny([request.auth.uid]);
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isSignedIn() && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid &&
                    get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.hasAny([request.auth.uid]);
      allow update, delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // -------------------------------
    // Communities
    match /communities/{communityId} {
      allow get: if isCommunityMember(communityId) || isAdmin();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdByUserId == request.auth.uid &&
                    request.resource.data.memberIds.hasAny([request.auth.uid]);
      allow update: if isOwner(resource.data.createdByUserId) || isAdmin();
      allow delete: if isOwner(resource.data.createdByUserId) || isAdmin();
    }

    match /communities/{communityId}/messages/{messageId} {
      allow get, list: if isCommunityMember(communityId) || isAdmin();
      allow create: if isCommunityMember(communityId) && request.resource.data.senderId == request.auth.uid &&
                    request.resource.data.communityId == communityId;
      allow update: if isOwner(resource.data.senderId) || isAdmin();
      allow delete: if isOwner(resource.data.senderId) || isAdmin();
    }

    match /communities/{communityId}/events/{eventId} {
      allow get, list: if isCommunityMember(communityId) || isAdmin();
      allow create: if isCommunityMember(communityId) && request.resource.data.creatorId == request.auth.uid &&
                    request.resource.data.communityId == communityId;
      allow update: if isOwner(resource.data.creatorId) || isAdmin();
      allow delete: if isOwner(resource.data.creatorId) || isAdmin();
    }

    // -------------------------------
    // Stand-alone events
    match /events/{eventId} {
      allow get: if isSignedIn() && resource.data.attendeeIds.hasAny([request.auth.uid]);
      allow list: if isSignedIn() && request.query.whereKeys[0] == 'attendeeIds' &&
                    request.query.whereValues[0] == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.organizerId == request.auth.uid;
      allow update: if isOwner(resource.data.organizerId) || isAdmin();
      allow delete: if isOwner(resource.data.organizerId) || isAdmin();
    }

    // -------------------------------
    // Knowledge resources
    match /knowledge_resources/{resourceId} {
      allow get, list: if true;
      allow create: if isProfessionalOrAdmin() && request.resource.data.authorId == request.auth.uid;
      allow update: if isOwner(resource.data.authorId) || isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

  }
}
